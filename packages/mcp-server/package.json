{
  "name": "@xstate-devtools/mcp",
  "version": "0.2.0",
  "description": "Model Context Protocol server for XState: list machines, describe structure, Mermaid diagrams, test paths, validation, find references, setup() coverage, events, and state detail — over any workspace, no VS Code required.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mjbeswick/xstate-devtools.git",
    "directory": "packages/mcp-server"
  },
  "keywords": [
    "xstate",
    "mcp",
    "model-context-protocol",
    "statechart",
    "ai"
  ],
  "bin": {
    "xstate-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node esbuild.js",
    "compile": "node esbuild.js",
    "check": "tsc -p ./ --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/node": "^18",
    "@types/vscode": "^1.95.0",
    "@xstate-devtools/diagram-core": "*",
    "esbuild": "^0.17.6",
    "fast-glob": "^3.3.0",
    "typescript": "^5",
    "vitest": "^2.0.0",
    "zod": "^3.23.0"
  }
}
