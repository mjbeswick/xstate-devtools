    "directory": "packages/mcp-server"
  },
  "keywords": ["xstate", "mcp", "model-context-protocol", "statechart", "ai"],
  "bin": {
    "xstate-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": ["dist"],
  "scripts": {
    "build": "node esbuild.js",
    "compile": "node esbuild.js",
    "check": "tsc -p ./ --noEmit",
