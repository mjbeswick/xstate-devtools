{
  "name": "xstate-debugger",
  "displayName": "XState Debugger",
  "description": "Live XState debugger: attach to running Node/SSR actors over the server adapter, inspect instances & context, time-travel the event log, and overlay live state on a statechart diagram.",
  "version": "0.2.0",
  "publisher": "MichaelBeswick",
  "license": "MIT",
  "icon": "images/icon.png",
  "homepage": "https://github.com/mjbeswick/xstate-devtools/tree/main/packages/vscode-debugger#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/mjbeswick/xstate-devtools.git",
    "directory": "packages/vscode-debugger"
  },
  "bugs": {
    "url": "https://github.com/mjbeswick/xstate-devtools/issues"
  },
  "keywords": [
    "xstate",
    "state machine",
    "statechart",
    "debugger",
    "inspector"
  ],
  "engines": {
    "vscode": "^1.78.0"
  },
  "categories": [
    "Debuggers",
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onView:xstateDebuggerInstances",
    "onView:xstateDebuggerContext",
    "onView:xstateDebuggerEvent",
    "onView:xstateEventsLog"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "xstate-debugger": [
        {
          "id": "xstateDebuggerInstances",
          "name": "Instances"
        },
        {
          "id": "xstateDebuggerContext",
          "name": "Context"
        },
        {
          "id": "xstateDebuggerEvent",
          "name": "Event"
        }
      ],
      "xstate-events": [
        {
          "type": "webview",
          "id": "xstateEventsLog",
          "name": "Events"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "xstate-debugger",
          "title": "XState Debugger",
          "icon": "resources/debugger.svg"
        }
      ],
      "panel": [
        {
          "id": "xstate-events",
          "title": "XState",
          "icon": "resources/debugger.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "xstateDebuggerInstances",
        "contents": "⏳ Checking setup…",
        "when": "!xstateDebugger.connected && xstateDebugger.setupChecking"
      },
      {
        "view": "xstateDebuggerInstances",
        "contents": "❌ No XState machines found in this workspace.\nThe debugger inspects running XState actors over a WebSocket — [XState docs](https://stately.ai/docs/xstate).\n[Check setup](command:xstateDebugger.recheckSetup)",
        "when": "!xstateDebugger.connected && !xstateDebugger.setupChecking && xstateDebugger.setup == no-xstate"
      },
      {
        "view": "xstateDebuggerInstances",
        "contents": "❌ This workspace uses XState but not @xstate-devtools/adapter.\nInstall it and wire createServerAdapter() into your app — [Setup guide](https://github.com/mjbeswick/xstate-devtools/tree/main/packages/vscode-debugger#readme), or [connect anyway](command:xstateDebugger.connect).\n[Check setup](command:xstateDebugger.recheckSetup)",
        "when": "!xstateDebugger.connected && !xstateDebugger.setupChecking && xstateDebugger.setup == no-adapter"
      },
      {
        "view": "xstateDebuggerInstances",
        "contents": "❌ @xstate-devtools/adapter is installed, but no createServerAdapter() call was found.\nThe debugger attaches to Node/SSR actors — add a createServerAdapter() inspector to your server (browser-only actors use the Chrome extension). [Setup guide](https://github.com/mjbeswick/xstate-devtools/tree/main/packages/vscode-debugger#readme), or [connect anyway](command:xstateDebugger.connect).\n[Check setup](command:xstateDebugger.recheckSetup)",
        "when": "!xstateDebugger.connected && !xstateDebugger.setupChecking && xstateDebugger.setup == no-server-adapter"
      },
      {
        "view": "xstateDebuggerInstances",
        "contents": "❌ Found createServerAdapter(), but its inspect isn't passed to any actor.\nPass it to your root actor: createActor(machine, { inspect }). [Setup guide](https://github.com/mjbeswick/xstate-devtools/tree/main/packages/vscode-debugger#readme), or [connect anyway](command:xstateDebugger.connect).\n[Check setup](command:xstateDebugger.recheckSetup)",
        "when": "!xstateDebugger.connected && !xstateDebugger.setupChecking && xstateDebugger.setup == inspect-not-wired"
      },
      {
        "view": "xstateDebuggerInstances",
        "contents": "✅ Setup looks ready.\nStart your app, then connect to inspect its actors.\n[Connect](command:xstateDebugger.connect)\nNot connecting? [Check setup](command:xstateDebugger.recheckSetup).",
        "when": "!xstateDebugger.connected && !xstateDebugger.setupChecking && xstateDebugger.setup == ready"
      },
      {
        "view": "xstateDebuggerInstances",
        "contents": "Start your app, then connect to inspect its XState actors.\n[Connect](command:xstateDebugger.connect)\nNot sure it's set up? [Check setup](command:xstateDebugger.recheckSetup).",
        "when": "!xstateDebugger.connected && !xstateDebugger.setupChecking && xstateDebugger.setup == unknown"
      }
    ],
    "commands": [
      {
        "command": "xstateDebugger.connect",
        "title": "Connect Live Debugger",
        "category": "XState Debugger",
        "icon": "$(plug)"
      },
      {
        "command": "xstateDebugger.disconnect",
        "title": "Disconnect Live Debugger",
        "category": "XState Debugger",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "xstateDebugger.toggle",
        "title": "Toggle Live Debugger Connection",
        "category": "XState Debugger"
      },
      {
        "command": "xstateDebugger.stepBack",
        "title": "Step Back",
        "category": "XState Debugger",
        "icon": "$(debug-step-back)"
      },
      {
        "command": "xstateDebugger.stepForward",
        "title": "Step Forward",
        "category": "XState Debugger",
        "icon": "$(debug-step-over)"
      },
      {
        "command": "xstateDebugger.backToLive",
        "title": "Back to Live",
        "category": "XState Debugger",
        "icon": "$(history)"
      },
      {
        "command": "xstateDebugger.clearEvents",
        "title": "Clear Event Log",
        "category": "XState Debugger",
        "icon": "$(clear-all)"
      },
      {
        "command": "xstateDebugger.recheckSetup",
        "title": "Check Setup",
        "category": "XState Debugger",
        "icon": "$(refresh)"
      },
      {
        "command": "xstateDebugger.copyContextValue",
        "title": "Copy Value",
        "category": "XState Debugger",
        "icon": "$(copy)"
      },
      {
        "command": "xstateDebugger.goToSource",
        "title": "Go to Source",
        "category": "XState Debugger",
        "icon": "$(go-to-file)"
      },
      {
        "command": "xstateDebugger.revealInDiagram",
        "title": "Reveal in Diagram",
        "category": "XState Debugger",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "xstateDebugger.diagramFromNode",
        "title": "Create Diagram From Here",
        "category": "XState Debugger",
        "icon": "$(type-hierarchy-sub)"
      },
      {
        "command": "xstateDebugger.sendEvent",
        "title": "Send Event…",
        "category": "XState Debugger",
        "icon": "$(send)"
      },
      {
        "command": "xstateDebugger.captureSnapshot",
        "title": "Capture Snapshot",
        "category": "XState Debugger",
        "icon": "$(device-camera)"
      },
      {
        "command": "xstateDebugger.restoreSnapshot",
        "title": "Restore Snapshot",
        "category": "XState Debugger",
        "icon": "$(debug-restart)"
      },
      {
        "command": "xstateDebugger.showStopped",
        "title": "Show Stopped Actors",
        "category": "XState Debugger",
        "icon": "$(eye)"
      },
      {
        "command": "xstateDebugger.hideStopped",
        "title": "Hide Stopped Actors",
        "category": "XState Debugger",
        "icon": "$(eye-closed)"
      },
      {
        "command": "xstateDebugger.followDiagram",
        "title": "Follow Actor in Diagram",
        "category": "XState Debugger",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "xstateDebugger.unfollowDiagram",
        "title": "Stop Following in Diagram",
        "category": "XState Debugger",
        "icon": "$(type-hierarchy-sub)"
      },
      {
        "command": "xstateDebugger.setNavigateDiagram",
        "title": "Navigate to Diagram on Select",
        "category": "XState Debugger"
      },
      {
        "command": "xstateDebugger.setNavigateCode",
        "title": "Navigate to Code on Select",
        "category": "XState Debugger"
      },
      {
        "command": "xstateDebugger.exportSession",
        "title": "Export Session…",
        "category": "XState Debugger",
        "icon": "$(save)"
      },
      {
        "command": "xstateDebugger.importSession",
        "title": "Import Session…",
        "category": "XState Debugger",
        "icon": "$(folder-opened)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "xstateDebugger.connect",
          "when": "view == xstateDebuggerInstances && !xstateDebugger.connected",
          "group": "navigation@0"
        },
        {
          "command": "xstateDebugger.disconnect",
          "when": "view == xstateDebuggerInstances && xstateDebugger.connected",
          "group": "navigation@0"
        },
        {
          "command": "xstateDebugger.hideStopped",
          "when": "view == xstateDebuggerInstances && xstateDebugger.showStopped",
          "group": "1_options@0"
        },
        {
          "command": "xstateDebugger.showStopped",
          "when": "view == xstateDebuggerInstances && !xstateDebugger.showStopped",
          "group": "1_options@0"
        },
        {
          "command": "xstateDebugger.unfollowDiagram",
          "when": "view == xstateDebuggerInstances && xstateDebugger.followDiagram",
          "group": "1_options@1"
        },
        {
          "command": "xstateDebugger.followDiagram",
          "when": "view == xstateDebuggerInstances && !xstateDebugger.followDiagram",
          "group": "1_options@1"
        },
        {
          "command": "xstateDebugger.setNavigateCode",
          "when": "view == xstateDebuggerInstances && xstateDebugger.navigateTarget == diagram",
          "group": "1_options@2"
        },
        {
          "command": "xstateDebugger.setNavigateDiagram",
          "when": "view == xstateDebuggerInstances && xstateDebugger.navigateTarget != diagram",
          "group": "1_options@2"
        },
        {
          "command": "xstateDebugger.stepBack",
          "when": "view == xstateEventsLog",
          "group": "navigation@0"
        },
        {
          "command": "xstateDebugger.stepForward",
          "when": "view == xstateEventsLog",
          "group": "navigation@1"
        },
        {
          "command": "xstateDebugger.backToLive",
          "when": "view == xstateEventsLog && xstateDebugger.timeTravelling",
          "group": "navigation@2"
        },
        {
          "command": "xstateDebugger.clearEvents",
          "when": "view == xstateEventsLog",
          "group": "navigation@3"
        },
        {
          "command": "xstateDebugger.importSession",
          "when": "view == xstateEventsLog",
          "group": "navigation@4"
        },
        {
          "command": "xstateDebugger.exportSession",
          "when": "view == xstateEventsLog",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "xstateDebugger.goToSource",
          "when": "view == xstateDebuggerInstances && (viewItem == xstateDebuggerActor || viewItem =~ /^xstateDebuggerState/)",
          "group": "navigation@0"
        },
        {
          "command": "xstateDebugger.revealInDiagram",
          "when": "view == xstateDebuggerInstances && (viewItem == xstateDebuggerActor || viewItem =~ /^xstateDebuggerState/)",
          "group": "navigation@1"
        },
        {
          "command": "xstateDebugger.diagramFromNode",
          "when": "view == xstateDebuggerInstances && viewItem == xstateDebuggerStateCompound",
          "group": "navigation@2"
        },
        {
          "command": "xstateDebugger.sendEvent",
          "when": "view == xstateDebuggerInstances && (viewItem == xstateDebuggerActor || viewItem =~ /^xstateDebuggerState/)",
          "group": "1_actor@0"
        },
        {
          "command": "xstateDebugger.captureSnapshot",
          "when": "view == xstateDebuggerInstances && viewItem == xstateDebuggerActor",
          "group": "1_actor@1"
        },
        {
          "command": "xstateDebugger.restoreSnapshot",
          "when": "view == xstateDebuggerInstances && viewItem == xstateDebuggerActor",
          "group": "1_actor@2"
        },
        {
          "command": "xstateDebugger.copyContextValue",
          "when": "view == xstateDebuggerContext && viewItem == xstateDebuggerContext",
          "group": "navigation@0"
        }
      ],
      "commandPalette": [
        {
          "command": "xstateDebugger.copyContextValue",
          "when": "false"
        },
        {
          "command": "xstateDebugger.goToSource",
          "when": "false"
        },
        {
          "command": "xstateDebugger.revealInDiagram",
          "when": "false"
        },
        {
          "command": "xstateDebugger.diagramFromNode",
          "when": "false"
        },
        {
          "command": "xstateDebugger.sendEvent",
          "when": "false"
        },
        {
          "command": "xstateDebugger.captureSnapshot",
          "when": "false"
        },
        {
          "command": "xstateDebugger.restoreSnapshot",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "xstateDebugger.stepBack",
        "key": "alt+left",
        "mac": "alt+left",
        "when": "focusedView == xstateEventsLog"
      },
      {
        "command": "xstateDebugger.stepForward",
        "key": "alt+right",
        "mac": "alt+right",
        "when": "focusedView == xstateEventsLog"
      }
    ],
    "configuration": {
      "title": "XState Debugger",
      "properties": {
        "xstateDebugger.url": {
          "type": "string",
          "default": "ws://127.0.0.1:9301",
          "description": "WebSocket URL of the running app's XState server adapter (createServerAdapter) that the live debugger connects to."
        },
        "xstateDebugger.showStopped": {
          "type": "boolean",
          "default": true,
          "description": "Show stopped actors in the XState Debugger Instances view."
        },
        "xstateDebugger.followDiagram": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open/reveal the statechart diagram for the selected actor, with its live state highlighted."
        },
        "xstateDebugger.navigateTarget": {
          "type": "string",
          "enum": [
            "diagram",
            "code"
          ],
          "default": "code",
          "description": "Where selecting an instance in the XState Debugger Instances view navigates: its statechart diagram, or its source code."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "bundle": "node esbuild.js",
    "compile": "node esbuild.js",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "dev": "node esbuild.js --watch",
    "check": "tsc -p ./ --noEmit",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.78.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "esbuild": "^0.17.6",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@xstate-devtools/diagram-core": "*",
    "@xstate-devtools/panel-core": "*",
    "@xstate-devtools/protocol": "*",
    "ws": "^8.20.0"
  }
}
