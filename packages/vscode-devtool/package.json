          "when": "false"
        },
        {
          "command": "xstateErrors.open",
          "when": "false"
        },
        {
          "command": "xstateErrors.copy",
          "when": "false"
        },
        {
          "command": "xstateMachineOutline.setErrorsGroupingFile",
          "when": "false"
        },
        {
          "command": "xstateMachineOutline.setErrorsGroupingSeverity",
          "when": "false"
        },
        {
          "command": "xstateMachineOutline.setErrorsGroupingFlat",
          "when": "false"
        },
        {
