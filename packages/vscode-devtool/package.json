        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "xstate-outline",
          "title": "xState Devtools",
          "icon": "resources/xstate.svg"
        }
      ]
    },
    "keybindings": [
      {
        "command": "xstateMachineOutline.goToImplementationSelected",
        "key": "f12",
        "mac": "f12",
        "when": "focusedView == xstateMachineOutline"
      },
      {
        "command": "xstateErrors.copy",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "focusedView == xstateMachineErrors"
      },
      {
        "command": "xstateMachineOutline.copyNode",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "focusedView == xstateMachineOutline"
      },
      {
        "command": "xstateMachineOutline.cutNode",
        "key": "ctrl+x",
        "mac": "cmd+x",
        "when": "focusedView == xstateMachineOutline"
      },
      {
        "command": "xstateMachineOutline.pasteNode",
        "key": "ctrl+v",
        "mac": "cmd+v",
        "when": "focusedView == xstateMachineOutline && xstateOutline.hasClipboard"
      }
    ]
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "vscode:prepublish": "npm run copy-codicons && npm run bundle",
    "copy-codicons": "node -e \"const fs=require('fs'),p=require('path');const dist=p.dirname(require.resolve('@vscode/codicons/package.json'))+'/dist';const out='resources/codicons';fs.mkdirSync(out,{recursive:true});for(const f of ['codicon.css','codicon.ttf'])fs.copyFileSync(p.join(dist,f),p.join(out,f));\"",
    "bundle": "node esbuild.js",
    "compile": "npm run copy-codicons && npm run bundle",
    "build": "npm run copy-codicons && npm run bundle",
    "watch": "npm run copy-codicons && node esbuild.js --watch",
    "dev": "npm run copy-codicons && node esbuild.js --watch",
    "check": "tsc -p ./ --noEmit",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/codicons": "^0.0.45",
    "esbuild": "^0.17.6",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@xstate-devtools/diagram-core": "*",
    "elkjs": "^0.11.1"
  }
