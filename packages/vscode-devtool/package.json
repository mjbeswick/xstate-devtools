{
  "name": "xstate-devtools",
  "displayName": "xState Devtools",
  "description": "XState developer tools: interactive outline, search, and navigation",
  "version": "1.19.0",
  "publisher": "MichaelBeswick",
  "license": "MIT",
  "icon": "images/icon.png",
  "homepage": "https://github.com/mjbeswick/xstate-devtools/tree/main/packages/vscode-devtool#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/mjbeswick/xstate-devtools.git",
    "directory": "packages/vscode-devtool"
  },
  "bugs": {
    "url": "https://github.com/mjbeswick/xstate-devtools/issues"
  },
  "keywords": [
    "xstate",
    "state machine",
    "statechart",
    "outline",
    "typescript"
  ],
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onView:xstateMachineOutline",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelTools": [
      {
        "name": "xstate_list_machines",
        "displayName": "List XState machines",
        "modelDescription": "List every XState machine found in the workspace, with its id, source file, line, and state count. Use this first to discover which machines exist.",
        "toolReferenceName": "xstateMachines",
        "canBeReferencedInPrompt": true,
        "icon": "$(list-tree)",
        "tags": [
          "xstate"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "xstate_describe_machine",
        "displayName": "Describe XState machine",
        "modelDescription": "Return the structure of one XState machine as JSON: its states (with hierarchy, initial/final/parallel flags, entry/exit actions, invoked services) and transitions (source, target, event). Identify the machine by its id.",
        "canBeReferencedInPrompt": true,
        "icon": "$(symbol-structure)",
        "tags": [
          "xstate"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "machine": {
              "type": "string",
              "description": "The machine's id (as reported by xstate_list_machines)."
            },
            "file": {
              "type": "string",
              "description": "Optional source file path to disambiguate machines that share an id."
            }
          },
          "required": [
            "machine"
          ]
        }
      },
      {
        "name": "xstate_machine_diagram",
        "displayName": "XState machine diagram (Mermaid)",
        "modelDescription": "Return a Mermaid `stateDiagram-v2` for one XState machine, identified by its id. Useful for visualising or documenting the machine.",
        "canBeReferencedInPrompt": true,
        "icon": "$(git-merge)",
        "tags": [
          "xstate"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "machine": {
              "type": "string",
              "description": "The machine's id."
            },
            "file": {
              "type": "string",
              "description": "Optional source file path to disambiguate."
            }
          },
          "required": [
            "machine"
          ]
        }
      },
      {
        "name": "xstate_test_paths",
        "displayName": "XState test paths",
        "modelDescription": "Return the shortest event sequence to reach each state of one XState machine (structural — guards assumed takeable), flag unreachable states, and include copy-paste test skeletons. Identify the machine by its id.",
        "canBeReferencedInPrompt": true,
        "icon": "$(beaker)",
        "tags": [
          "xstate"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "machine": {
              "type": "string",
              "description": "The machine's id."
            },
            "file": {
              "type": "string",
              "description": "Optional source file path to disambiguate."
            }
          },
          "required": [
            "machine"
          ]
        }
      },
      {
        "name": "xstate_validate",
        "displayName": "Validate XState machines",
        "modelDescription": "Run XState diagnostics over the workspace (or one file): invalid config properties, unknown transition targets, unreachable states, etc. Returns the problems found with file, line, severity, and message.",
        "canBeReferencedInPrompt": true,
        "icon": "$(checklist)",
        "tags": [
          "xstate"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "file": {
              "type": "string",
              "description": "Optional source file path. Omit to validate every XState file in the workspace."
            }
          }
        }
      }
    ],
    "views": {
      "xstate-outline": [
        {
          "type": "webview",
          "id": "xstateMachineOutlineSearch",
          "name": "Search",
          "when": "true"
        },
        {
          "id": "xstateMachineOutline",
          "name": "Outline"
        },
        {
          "id": "xstateMachineNavigator",
          "name": "Transitions"
        },
        {
          "id": "xstateMachineErrors",
          "name": "Errors"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "xstateMachineOutline",
        "contents": "All machines in this file are state configs, which are hidden.\n[Show State Configs](command:xstateMachineOutline.setStateConfigsShow)",
        "when": "xstateOutline.emptyReason == stateConfigsHidden"
      },
      {
        "view": "xstateMachineOutline",
        "contents": "No XState machines found in this file.\n[Search the Whole Workspace](command:xstateMachineOutline.setScopeWorkspace)",
        "when": "xstateOutline.emptyReason == noMachinesInFile"
      },
      {
        "view": "xstateMachineOutline",
        "contents": "Open a JavaScript or TypeScript file to see its XState machines, or search the whole workspace.\n[Search the Whole Workspace](command:xstateMachineOutline.setScopeWorkspace)",
        "when": "xstateOutline.emptyReason == noEditor"
      },
      {
        "view": "xstateMachineOutline",
        "contents": "No XState machines found in the workspace.\n[Rescan Workspace](command:xstateMachineOutline.refresh)\n[Search the Current File Only](command:xstateMachineOutline.setScopeFile)",
        "when": "xstateOutline.emptyReason == noMachinesInWorkspace && workbenchState != empty"
      },
      {
        "view": "xstateMachineOutline",
        "contents": "Open a folder to scan it for XState machines.\n[Open Folder](command:vscode.openFolder)",
        "when": "xstateOutline.emptyReason == noMachinesInWorkspace && workbenchState == empty"
      }
    ],
    "commands": [
      {
        "command": "xstateMachineOutline.refresh",
        "title": "Refresh XState Outline",
        "icon": "$(refresh)"
      },
      {
        "command": "xstateMachineOutline.setScopeFile",
        "title": "Scope: file",
        "icon": "$(file)"
      },
      {
        "command": "xstateMachineOutline.setScopeFileActive",
        "title": "Scope: file",
        "icon": "$(file)"
      },
      {
        "command": "xstateMachineOutline.setScopeWorkspace",
        "title": "Scope: workspace",
        "icon": "$(folder)"
      },
      {
        "command": "xstateMachineOutline.setScopeWorkspaceActive",
        "title": "Scope: workspace",
        "icon": "$(folder)"
      },
      {
        "command": "xstateMachineOutline.setViewGrouped",
        "title": "View: grouped",
        "icon": "$(list-tree)"
      },
      {
        "command": "xstateMachineOutline.setViewGroupedActive",
        "title": "View: grouped",
        "icon": "$(list-tree)"
      },
      {
        "command": "xstateMachineOutline.setViewFlat",
        "title": "View: flat",
        "icon": "$(list-flat)"
      },
      {
        "command": "xstateMachineOutline.setViewFlatActive",
        "title": "View: flat",
        "icon": "$(list-flat)"
      },
      {
        "command": "xstateMachineOutline.setStateConfigsShow",
        "title": "State configs: show",
        "icon": "$(eye)"
      },
      {
        "command": "xstateMachineOutline.setStateConfigsShowActive",
        "title": "State configs: show",
        "icon": "$(eye)"
      },
      {
        "command": "xstateMachineOutline.setStateConfigsHide",
        "title": "State configs: hide",
        "icon": "$(eye-closed)"
      },
      {
        "command": "xstateMachineOutline.setStateConfigsHideActive",
        "title": "State configs: hide",
        "icon": "$(eye-closed)"
      },
      {
        "command": "xstateMachineOutline.toggleFollowCursor",
        "title": "Cursor: follow",
        "icon": "$(pin)"
      },
      {
        "command": "xstateMachineOutline.toggleFollowCursorActive",
        "title": "Cursor: do not follow",
        "icon": "$(pinned)"
      },
      {
        "command": "xstateMachineOutline.setNavDiagram",
        "title": "Navigate: diagram",
        "icon": "$(git-merge)"
      },
      {
        "command": "xstateMachineOutline.setNavCode",
        "title": "Navigate: code",
        "icon": "$(code)"
      },
      {
        "command": "xstateMachineOutline.toggleGraphSyncExpansion",
        "title": "Graph: reflect tree expansion",
        "icon": "$(list-filter)"
      },
      {
        "command": "xstateMachineOutline.toggleGraphSyncExpansionActive",
        "title": "Graph: render full tree",
        "icon": "$(list-tree)"
      },
      {
        "command": "xstateMachineOutline.setGroupHandlersOn",
        "title": "Handlers: group under on",
        "icon": "$(group-by-ref-type)"
      },
      {
        "command": "xstateMachineOutline.setGroupHandlersOff",
        "title": "Handlers: flat",
        "icon": "$(ungroup-by-ref-type)"
      },
      {
        "command": "xstateMachineOutline.setSortChildrenSorted",
        "title": "Sort children: A–Z",
        "icon": "$(list-ordered)"
      },
      {
        "command": "xstateMachineOutline.setSortChildrenByType",
        "title": "Sort children: by type, then name",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "xstateMachineOutline.setSortChildrenOriginal",
        "title": "Sort children: source order",
        "icon": "$(list-unordered)"
      },
      {
        "command": "xstateMachineOutlineSearch.setSortRelevance",
        "title": "Sort results by: Relevance"
      },
      {
        "command": "xstateMachineOutlineSearch.setSortRelevanceActive",
        "title": "Sort results by: $(check) Relevance"
      },
      {
        "command": "xstateMachineOutlineSearch.setSortName",
        "title": "Sort results by: Name"
      },
      {
        "command": "xstateMachineOutlineSearch.setSortNameActive",
        "title": "Sort results by: $(check) Name"
      },
      {
        "command": "xstateMachineOutlineSearch.setSortType",
        "title": "Sort results by: Type"
      },
      {
        "command": "xstateMachineOutlineSearch.setSortTypeActive",
        "title": "Sort results by: $(check) Type"
      },
      {
        "command": "xstateMachineOutlineSearch.setFuzzyOn",
        "title": "Fuzzy match"
      },
      {
        "command": "xstateMachineOutlineSearch.setFuzzyOff",
        "title": "$(check) Fuzzy match"
      },
      {
        "command": "xstateMachineOutline.setErrorsGroupingFile",
        "title": "Group: by file",
        "icon": "$(list-tree)"
      },
      {
        "command": "xstateMachineOutline.setErrorsGroupingSeverity",
        "title": "Group: by severity",
        "icon": "$(warning)"
      },
      {
        "command": "xstateMachineOutline.setErrorsGroupingFlat",
        "title": "Group: flat",
        "icon": "$(list-flat)"
      },
      {
        "command": "xstateErrors.open",
        "title": "Go to Problem"
      },
      {
        "command": "xstateErrors.copy",
        "title": "Copy",
        "icon": "$(copy)"
      },
      {
        "command": "xstateMachineOutline.setErrorsFilterAll",
        "title": "Show: all",
        "icon": "$(list-filter)"
      },
      {
        "command": "xstateMachineOutline.setErrorsFilterWarnings",
        "title": "Show: warnings & errors",
        "icon": "$(warning)"
      },
      {
        "command": "xstateMachineOutline.setErrorsFilterErrors",
        "title": "Show: errors only",
        "icon": "$(error)"
      },
      {
        "command": "xstateMachineOutline.navigateToNode",
        "title": "Go to Source"
      },
      {
        "command": "xstateMachineOutline.goToSource",
        "title": "Go to Source",
        "category": "XState",
        "icon": "$(go-to-file)"
      },
      {
        "command": "xstateMachineOutline.goToImplementation",
        "title": "Go to Implementation",
        "icon": "$(go-to-file)"
      },
      {
        "command": "xstateMachineOutline.showTransitions",
        "title": "Show Transitions",
        "icon": "$(arrow-both)"
      },
      {
        "command": "xstateNavigator.openTransition",
        "title": "Go to State"
      },
      {
        "command": "xstateMachineOutline.filter",
        "title": "Filter",
        "icon": "$(search)"
      },
      {
        "command": "xstateMachineOutline.clearFilter",
        "title": "Clear Filter",
        "icon": "$(search-stop)"
      },
      {
        "command": "xstateMachineOutline.goToImplementationSelected",
        "title": "Go to Implementation",
        "icon": "$(go-to-file)"
      },
      {
        "command": "xstateMachineOutline.editNode",
        "title": "Edit"
      },
      {
        "command": "xstateMachineOutline.addChildState",
        "title": "Add Child State"
      },
      {
        "command": "xstateMachineOutline.addTransition",
        "title": "Add Transition"
      },
      {
        "command": "xstateMachineOutline.addReference",
        "title": "Add Action / Guard / Invoke"
      },
      {
        "command": "xstateMachineOutline.deleteNode",
        "title": "Delete"
      },
      {
        "command": "xstateMachineOutline.setDescription",
        "title": "Set Description"
      },
      {
        "command": "xstateMachineOutline.copyNode",
        "title": "Copy"
      },
      {
        "command": "xstateMachineOutline.cutNode",
        "title": "Cut"
      },
      {
        "command": "xstateMachineOutline.pasteNode",
        "title": "Paste"
      },
      {
        "command": "xstateMachineOutline.openGraphView",
        "title": "View State Diagram",
        "icon": "$(git-merge)"
      },
      {
        "command": "xstateMachineOutline.openGraphViewAtCursor",
        "title": "View State Diagram",
        "category": "XState",
        "icon": "$(git-merge)"
      },
      {
        "command": "xstateMachineOutline.openGraphViewForNode",
        "title": "View State Diagram",
        "category": "XState"
      },
      {
        "command": "xstateMachineOutline.exportMermaid",
        "title": "Export as Mermaid",
        "category": "XState",
        "icon": "$(markdown)"
      },
      {
        "command": "xstateMachineOutline.generateSetupStubs",
        "title": "Generate Setup Stubs",
        "category": "XState",
        "icon": "$(symbol-method)"
      },
      {
        "command": "xstateMachineOutline.generateTestPaths",
        "title": "Generate Test Paths",
        "category": "XState",
        "icon": "$(beaker)"
      }
    ],
    "configuration": {
      "title": "XState Outline",
      "properties": {
        "xstateOutline.defaultScope": {
          "type": "string",
          "enum": [
            "file",
            "workspace"
          ],
          "default": "workspace",
          "description": "Default scope for XState Outline view (file or workspace)"
        },
        "xstateOutline.defaultViewMode": {
          "type": "string",
          "enum": [
            "grouped",
            "flat"
          ],
          "default": "flat",
          "description": "Default view mode (grouped by file or flat list of machines)"
        },
        "xstateOutline.showStateConfigs": {
          "type": "boolean",
          "default": false,
          "description": "Show createStateConfig/stateConfig patterns in the outline"
        },
        "xstateOutline.followCursor": {
          "type": "boolean",
          "default": true,
          "description": "Automatically reveal the tree item corresponding to the cursor position"
        },
        "xstateOutline.navTarget": {
          "type": "string",
          "enum": [
            "code",
            "diagram"
          ],
          "enumDescriptions": [
            "Clicking a state/machine in the outline jumps to its source",
            "Clicking a state/machine focuses it in the diagram (opening the diagram if needed)"
          ],
          "default": "code",
          "description": "Where clicking a tree node navigates: source code or the statechart diagram"
        },
        "xstateOutline.graphReflectsTreeExpansion": {
          "type": "boolean",
          "default": true,
          "description": "Make the visual graph selectively render only states that are expanded in the tree outline"
        },
        "xstateOutline.codeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show a CodeLens above each machine with state/transition counts and a 'View Diagram' action"
        },
        "xstateOutline.showInternalTransitions": {
          "type": "boolean",
          "default": true,
          "description": "Show internal (action-only) transitions inside state boxes in the diagram (toggle live from the diagram toolbar)"
        },
        "xstateOutline.groupEventHandlers": {
          "type": "boolean",
          "default": false,
          "description": "Group a state's event-handler transitions under an `on` node in the outline"
        },
        "xstateOutline.sortChildren": {
          "type": "string",
          "enum": [
            "original",
            "sorted",
            "type-name"
          ],
          "enumDescriptions": [
            "Source order",
            "Alphabetical by name",
            "Grouped by type, then alphabetical by name"
          ],
          "default": "original",
          "description": "Order of child nodes in the outline: source order, alphabetical (sorted), or grouped by type then name (type-name)"
        },
        "xstateOutline.searchSort": {
          "type": "string",
          "enum": [
            "relevance",
            "name",
            "type"
          ],
          "enumDescriptions": [
            "Source order (as found)",
            "Alphabetical by name",
            "Grouped by type, then alphabetical by name"
          ],
          "default": "relevance",
          "description": "Default ordering for search results"
        },
        "xstateOutline.searchFuzzy": {
          "type": "boolean",
          "default": false,
          "description": "Match search by fuzzy subsequence (e.g. \"kp\" matches \"keep\") instead of substring, ranking the best matches first"
        },
        "xstateOutline.errorsGrouping": {
          "type": "string",
          "enum": [
            "file",
            "severity",
            "flat"
          ],
          "default": "file",
          "description": "How the Errors pane groups problems: by file, by severity, or a flat list"
        },
        "xstateOutline.errorsFilter": {
          "type": "string",
          "enum": [
            "all",
            "warning",
            "error"
          ],
          "enumDescriptions": [
            "Show everything, including deprecations and unused-setup hints",
            "Show errors and warnings (hide informational hints)",
            "Show only errors — problems that fail at runtime"
          ],
          "default": "warning",
          "description": "Minimum severity shown in the Errors pane"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "xstateMachineOutlineSearch.setSortRelevance",
          "when": "view == xstateMachineOutlineSearch && xstateOutline.searchSortMode != relevance",
          "group": "1_sort@1"
        },
        {
          "command": "xstateMachineOutlineSearch.setSortRelevanceActive",
          "when": "view == xstateMachineOutlineSearch && xstateOutline.searchSortMode == relevance",
          "group": "1_sort@1"
        },
        {
          "command": "xstateMachineOutlineSearch.setSortName",
          "when": "view == xstateMachineOutlineSearch && xstateOutline.searchSortMode != name",
          "group": "1_sort@2"
        },
        {
          "command": "xstateMachineOutlineSearch.setSortNameActive",
          "when": "view == xstateMachineOutlineSearch && xstateOutline.searchSortMode == name",
          "group": "1_sort@2"
        },
        {
          "command": "xstateMachineOutlineSearch.setSortType",
          "when": "view == xstateMachineOutlineSearch && xstateOutline.searchSortMode != type",
          "group": "1_sort@3"
        },
        {
          "command": "xstateMachineOutlineSearch.setSortTypeActive",
          "when": "view == xstateMachineOutlineSearch && xstateOutline.searchSortMode == type",
          "group": "1_sort@3"
        },
        {
          "command": "xstateMachineOutlineSearch.setFuzzyOn",
          "when": "view == xstateMachineOutlineSearch && !xstateOutline.searchFuzzy",
          "group": "2_match@1"
        },
        {
          "command": "xstateMachineOutlineSearch.setFuzzyOff",
          "when": "view == xstateMachineOutlineSearch && xstateOutline.searchFuzzy",
          "group": "2_match@1"
        },
        {
          "command": "xstateMachineOutline.refresh",
          "when": "view == xstateMachineOutline",
          "group": "navigation@0"
        },
        {
          "command": "xstateMachineOutline.toggleGraphSyncExpansion",
          "when": "view == xstateMachineOutline && !xstateOutline.graphReflectsTreeExpansion",
          "group": "1_visibility@1"
        },
        {
          "command": "xstateMachineOutline.toggleGraphSyncExpansionActive",
          "when": "view == xstateMachineOutline && xstateOutline.graphReflectsTreeExpansion",
          "group": "1_visibility@1"
        },
        {
          "command": "xstateMachineOutline.toggleFollowCursor",
          "when": "view == xstateMachineOutline && !xstateOutline.followCursor",
          "group": "0_cursor@1"
        },
        {
          "command": "xstateMachineOutline.toggleFollowCursorActive",
          "when": "view == xstateMachineOutline && xstateOutline.followCursor",
          "group": "0_cursor@1"
        },
        {
          "command": "xstateMachineOutline.setNavDiagram",
          "when": "view == xstateMachineOutline && !xstateOutline.navIsDiagram",
          "group": "0_nav@1"
        },
        {
          "command": "xstateMachineOutline.setNavCode",
          "when": "view == xstateMachineOutline && xstateOutline.navIsDiagram",
          "group": "0_nav@1"
        },
        {
          "command": "xstateMachineOutline.setScopeFile",
          "when": "view == xstateMachineOutline && xstateOutline.scopeIsWorkspace",
          "group": "1_scope@1"
        },
        {
          "command": "xstateMachineOutline.setScopeWorkspace",
          "when": "view == xstateMachineOutline && !xstateOutline.scopeIsWorkspace",
          "group": "1_scope@1"
        },
        {
          "command": "xstateMachineOutline.setViewGrouped",
          "when": "view == xstateMachineOutline && xstateOutline.viewModeIsFlat",
          "group": "2_view@1"
        },
        {
          "command": "xstateMachineOutline.setViewFlat",
          "when": "view == xstateMachineOutline && !xstateOutline.viewModeIsFlat",
          "group": "2_view@1"
        },
        {
          "command": "xstateMachineOutline.setStateConfigsShow",
          "when": "view == xstateMachineOutline && !xstateOutline.showStateConfigs",
          "group": "3_configs@1"
        },
        {
          "command": "xstateMachineOutline.setStateConfigsHide",
          "when": "view == xstateMachineOutline && xstateOutline.showStateConfigs",
          "group": "3_configs@1"
        },
        {
          "command": "xstateMachineOutline.setGroupHandlersOn",
          "when": "view == xstateMachineOutline && !xstateOutline.groupEventHandlers",
          "group": "4_handlers@1"
        },
        {
          "command": "xstateMachineOutline.setGroupHandlersOff",
          "when": "view == xstateMachineOutline && xstateOutline.groupEventHandlers",
          "group": "4_handlers@1"
        },
        {
          "command": "xstateMachineOutline.setSortChildrenSorted",
          "when": "view == xstateMachineOutline && xstateOutline.sortChildrenMode == original",
          "group": "5_sort@1"
        },
        {
          "command": "xstateMachineOutline.setSortChildrenByType",
          "when": "view == xstateMachineOutline && xstateOutline.sortChildrenMode == sorted",
          "group": "5_sort@1"
        },
        {
          "command": "xstateMachineOutline.setSortChildrenOriginal",
          "when": "view == xstateMachineOutline && xstateOutline.sortChildrenMode == type-name",
          "group": "5_sort@1"
        },
        {
          "command": "xstateMachineOutline.setErrorsFilterAll",
          "when": "view == xstateMachineErrors && xstateErrors.filter != all",
          "group": "navigation@0"
        },
        {
          "command": "xstateMachineOutline.setErrorsFilterWarnings",
          "when": "view == xstateMachineErrors && xstateErrors.filter != warning",
          "group": "navigation@1"
        },
        {
          "command": "xstateMachineOutline.setErrorsFilterErrors",
          "when": "view == xstateMachineErrors && xstateErrors.filter != error",
          "group": "navigation@2"
        },
        {
          "command": "xstateMachineOutline.setErrorsGroupingFile",
          "when": "view == xstateMachineErrors && xstateErrors.grouping != file",
          "group": "navigation@3"
        },
        {
