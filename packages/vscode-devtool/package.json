          "when": "view == xstateMachineErrors && xstateErrors.grouping != flat",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "xstateMachineOutline.goToSource",
          "when": "view == xstateMachineOutline && xstateOutline.navIsDiagram && (viewItem == machine || viewItem == state)",
          "group": "navigation@0"
