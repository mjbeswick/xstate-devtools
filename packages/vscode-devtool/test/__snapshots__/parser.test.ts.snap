                "label": "red",
                "type": "target",
              },
            ],
            "label": "TIMER",
            "type": "transition",
          },
          {
            "children": [
              {
                "label": "flashing",
                "type": "target",
              },
            ],
            "label": "POWER_OUTAGE",
            "type": "transition",
          },
        ],
        "description": "Warning phase — traffic should slow and prepare to stop.",
        "label": "yellow",
        "type": "state",
      },
      {
        "children": [
          {
            "children": [
              {
                "children": [
                  {
                    "label": "flashWarning",
                    "type": "target",
                  },
                ],
                "label": "TIMER",
                "type": "transition",
              },
            ],
            "description": "Pedestrians may cross.",
            "initial": true,
            "label": "walk",
            "type": "state",
          },
          {
            "children": [
              {
                "children": [
                  {
                    "label": "dontWalk",
                    "type": "target",
                  },
                ],
                "label": "TIMER",
                "type": "transition",
              },
            ],
            "description": "Crossing signal flashes — pedestrians should finish crossing.",
            "label": "flashWarning",
            "type": "state",
          },
          {
            "description": "Crossing is closed. Pedestrian sequence complete.",
            "final": true,
            "label": "dontWalk",
            "type": "state",
          },
          {
            "children": [
              {
                "label": "flashing",
                "type": "target",
              },
            ],
            "label": "POWER_OUTAGE",
            "type": "transition",
          },
          {
            "children": [
              {
                "label": "green",
                "type": "target",
              },
            ],
            "label": "onDone",
            "type": "transition",
          },
          {
            "label": "countCycle",
            "type": "entry",
          },
        ],
        "description": "Traffic is stopped. Pedestrian crossing sequence runs as a nested region.",
        "label": "red",
        "type": "state",
      },
      {
        "children": [
          {
            "children": [
              {
                "label": "nightMode",
                "type": "guard",
              },
              {
                "label": "red",
                "type": "target",
              },
            ],
            "label": "POWER_RESTORED",
            "type": "transition",
          },
          {
            "label": "logChange",
            "type": "exit",
          },
        ],
        "description": "Fault mode: light flashes amber due to a power outage. Night mode guard determines return target.",
        "label": "flashing",
        "type": "state",
      },
      {
        "children": [
          {
            "label": "cycles: 0",
            "type": "contextProperty",
          },
        ],
        "label": "context",
        "type": "context",
      },
    ],
    "description": "Controls a standard traffic light with pedestrian crossing support and a fault mode for power outages.",
    "label": "trafficLight",
    "type": "machine",
  },
]
`;
