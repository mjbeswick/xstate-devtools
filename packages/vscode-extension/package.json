{
  "name": "xstate-devtools",
  "displayName": "xState Devtools",
  "description": "XState developer tools: interactive outline, search, and navigation",
  "version": "1.16.0",
  "publisher": "MichaelBeswick",
  "license": "MIT",
  "icon": "images/icon.png",
  "homepage": "https://github.com/mjbeswick/xstate-devtools/tree/main/packages/vscode-extension#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/mjbeswick/xstate-devtools.git",
    "directory": "packages/vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/mjbeswick/xstate-devtools/issues"
  },
  "keywords": [
    "xstate",
    "state machine",
    "statechart",
    "outline",
    "typescript"
  ],
  "engines": {
    "vscode": "^1.78.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onView:xstateMachineOutline",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "xstate-outline": [
        {
          "type": "webview",
          "id": "xstateMachineOutlineSearch",
          "name": "Search",
          "when": "true"
        },
        {
          "id": "xstateMachineOutline",
          "name": "Outline"
        },
        {
          "id": "xstateMachineNavigator",
          "name": "Transitions"
        },
        {
          "id": "xstateMachineErrors",
          "name": "Errors"
        }
      ],
      "xstate-debugger": [
        {
          "id": "xstateDebuggerInstances",
          "name": "Instances"
        },
        {
          "id": "xstateDebuggerContext",
          "name": "Context"
        }
      ],
      "xstate-events": [
        {
          "type": "webview",
          "id": "xstateEventsLog",
          "name": "Events"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "xstateDebuggerInstances",
        "contents": "No XState machines found in this workspace.\nThe debugger inspects running XState actors over a WebSocket.\n[XState docs](https://stately.ai/docs/xstate)",
        "when": "!xstateDebugger.connected && xstateDebugger.setup == no-xstate"
      },
      {
        "view": "xstateDebuggerInstances",
        "contents": "This workspace uses XState but not @xstate-devtools/adapter.\nInstall it and wire createServerAdapter() into your app to debug.\n[Setup guide](https://github.com/mjbeswick/xstate-devtools/tree/main/packages/vscode-extension#-live-debugger)\n[Connect anyway](command:xstateDebugger.connect)",
        "when": "!xstateDebugger.connected && xstateDebugger.setup == no-adapter"
      },
      {
        "view": "xstateDebuggerInstances",
        "contents": "@xstate-devtools/adapter is installed, but no createServerAdapter() call was found.\nThe VS Code debugger attaches to Node/SSR actors — add a createServerAdapter() inspector to your server. (Browser-only actors use the Chrome extension.)\n[Setup guide](https://github.com/mjbeswick/xstate-devtools/tree/main/packages/vscode-extension#-live-debugger)\n[Connect anyway](command:xstateDebugger.connect)",
        "when": "!xstateDebugger.connected && xstateDebugger.setup == no-server-adapter"
      },
      {
        "view": "xstateDebuggerInstances",
        "contents": "Found createServerAdapter(), but its inspect isn't passed to any actor.\nPass it when creating your root actor: createActor(machine, { inspect }).\n[Setup guide](https://github.com/mjbeswick/xstate-devtools/tree/main/packages/vscode-extension#-live-debugger)\n[Recheck](command:xstateDebugger.recheckSetup)\n[Connect anyway](command:xstateDebugger.connect)",
        "when": "!xstateDebugger.connected && xstateDebugger.setup == inspect-not-wired"
      },
      {
        "view": "xstateDebuggerInstances",
        "contents": "Start your app, then connect to inspect its XState actors.\n[Connect](command:xstateDebugger.connect)\n[Recheck setup](command:xstateDebugger.recheckSetup)",
        "when": "!xstateDebugger.connected && (xstateDebugger.setup == ready || xstateDebugger.setup == unknown)"
      },
      {
        "view": "xstateDebuggerInstances",
        "contents": "Connected — waiting for actors.\nIf your adapter starts lazily (e.g. inside a route loader), load a page so it initialises.\n[Disconnect](command:xstateDebugger.disconnect)",
        "when": "xstateDebugger.connected"
      },
      {
        "view": "xstateMachineOutline",
        "contents": "All machines in this file are state configs, which are hidden.\n[Show State Configs](command:xstateMachineOutline.setStateConfigsShow)",
        "when": "xstateOutline.emptyReason == stateConfigsHidden"
      },
      {
        "view": "xstateMachineOutline",
        "contents": "No XState machines found in this file.\n[Search the Whole Workspace](command:xstateMachineOutline.setScopeWorkspace)",
        "when": "xstateOutline.emptyReason == noMachinesInFile"
      },
      {
        "view": "xstateMachineOutline",
        "contents": "Open a JavaScript or TypeScript file to see its XState machines, or search the whole workspace.\n[Search the Whole Workspace](command:xstateMachineOutline.setScopeWorkspace)",
        "when": "xstateOutline.emptyReason == noEditor"
      },
      {
        "view": "xstateMachineOutline",
        "contents": "No XState machines found in the workspace.\n[Rescan Workspace](command:xstateMachineOutline.refresh)\n[Search the Current File Only](command:xstateMachineOutline.setScopeFile)",
        "when": "xstateOutline.emptyReason == noMachinesInWorkspace && workbenchState != empty"
      },
      {
        "view": "xstateMachineOutline",
        "contents": "Open a folder to scan it for XState machines.\n[Open Folder](command:vscode.openFolder)",
        "when": "xstateOutline.emptyReason == noMachinesInWorkspace && workbenchState == empty"
      }
    ],
    "commands": [
      {
        "command": "xstateDebugger.connect",
        "title": "Connect Live Debugger",
        "category": "XState Debugger",
        "icon": "$(plug)"
      },
      {
        "command": "xstateDebugger.disconnect",
