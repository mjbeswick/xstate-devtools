        "category": "XState Debugger",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "xstateDebugger.toggle",
        "title": "Toggle Live Debugger Connection",
        "category": "XState Debugger"
      },
      {
        "command": "xstateDebugger.stepBack",
        "title": "Step Back",
        "category": "XState Debugger",
        "icon": "$(debug-step-back)"
      },
      {
        "command": "xstateDebugger.stepForward",
        "title": "Step Forward",
        "category": "XState Debugger",
        "icon": "$(debug-step-over)"
      },
      {
        "command": "xstateDebugger.backToLive",
        "title": "Back to Live",
        "category": "XState Debugger",
        "icon": "$(history)"
      },
      {
        "command": "xstateDebugger.clearEvents",
        "title": "Clear Event Log",
        "category": "XState Debugger",
        "icon": "$(clear-all)"
      },
      {
        "command": "xstateDebugger.recheckSetup",
        "title": "Recheck Setup",
        "category": "XState Debugger",
        "icon": "$(refresh)"
      },
      {
        "command": "xstateDebugger.copyContextValue",
        "title": "Copy Value",
        "category": "XState Debugger",
        "icon": "$(copy)"
      },
      {
        "command": "xstateDebugger.goToSource",
        "title": "Go to Source",
        "category": "XState Debugger",
        "icon": "$(go-to-file)"
      },
      {
        "command": "xstateDebugger.revealInDiagram",
        "title": "Reveal in Diagram",
        "category": "XState Debugger",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "xstateDebugger.sendEvent",
        "title": "Send Event…",
        "category": "XState Debugger",
        "icon": "$(send)"
      },
      {
        "command": "xstateDebugger.captureSnapshot",
        "title": "Capture Snapshot",
        "category": "XState Debugger",
        "icon": "$(device-camera)"
      },
      {
        "command": "xstateDebugger.restoreSnapshot",
        "title": "Restore Snapshot",
        "category": "XState Debugger",
        "icon": "$(debug-restart)"
      },
      {
        "command": "xstateDebugger.showStopped",
        "title": "Show Stopped Actors",
        "category": "XState Debugger",
        "icon": "$(eye)"
      },
      {
        "command": "xstateDebugger.hideStopped",
        "title": "Hide Stopped Actors",
        "category": "XState Debugger",
        "icon": "$(eye-closed)"
      },
      {
        "command": "xstateDebugger.exportSession",
        "title": "Export Session…",
        "category": "XState Debugger",
        "icon": "$(save)"
      },
      {
        "command": "xstateDebugger.importSession",
        "title": "Import Session…",
        "category": "XState Debugger",
        "icon": "$(folder-opened)"
      },
      {
        "command": "xstateMachineOutline.refresh",
        "title": "Refresh XState Outline",
        "icon": "$(refresh)"
      },
      {
        "command": "xstateMachineOutline.setScopeFile",
        "title": "Scope: file",
        "icon": "$(file)"
      },
      {
        "command": "xstateMachineOutline.setScopeFileActive",
        "title": "Scope: file",
        "icon": "$(file)"
      },
      {
        "command": "xstateMachineOutline.setScopeWorkspace",
        "title": "Scope: workspace",
        "icon": "$(folder)"
      },
      {
        "command": "xstateMachineOutline.setScopeWorkspaceActive",
        "title": "Scope: workspace",
        "icon": "$(folder)"
      },
      {
        "command": "xstateMachineOutline.setViewGrouped",
        "title": "View: grouped",
        "icon": "$(list-tree)"
      },
      {
        "command": "xstateMachineOutline.setViewGroupedActive",
        "title": "View: grouped",
        "icon": "$(list-tree)"
      },
      {
        "command": "xstateMachineOutline.setViewFlat",
        "title": "View: flat",
        "icon": "$(list-flat)"
      },
      {
        "command": "xstateMachineOutline.setViewFlatActive",
        "title": "View: flat",
        "icon": "$(list-flat)"
      },
      {
        "command": "xstateMachineOutline.setStateConfigsShow",
        "title": "State configs: show",
        "icon": "$(eye)"
      },
      {
        "command": "xstateMachineOutline.setStateConfigsShowActive",
        "title": "State configs: show",
        "icon": "$(eye)"
      },
      {
        "command": "xstateMachineOutline.setStateConfigsHide",
        "title": "State configs: hide",
        "icon": "$(eye-closed)"
      },
      {
        "command": "xstateMachineOutline.setStateConfigsHideActive",
        "title": "State configs: hide",
        "icon": "$(eye-closed)"
      },
      {
        "command": "xstateMachineOutline.toggleFollowCursor",
        "title": "Cursor: follow"
      },
      {
        "command": "xstateMachineOutline.toggleFollowCursorActive",
        "title": "Cursor: do not follow"
      },
      {
        "command": "xstateMachineOutline.setNavDiagram",
        "title": "Navigate: diagram"
      },
      {
        "command": "xstateMachineOutline.setNavCode",
        "title": "Navigate: code"
      },
      {
        "command": "xstateMachineOutline.toggleGraphSyncExpansion",
        "title": "Graph: reflect tree expansion",
        "icon": "$(list-filter)"
      },
      {
        "command": "xstateMachineOutline.toggleGraphSyncExpansionActive",
        "title": "Graph: render full tree",
        "icon": "$(list-tree)"
      },
      {
        "command": "xstateMachineOutline.setGroupHandlersOn",
        "title": "Handlers: group under on"
      },
      {
        "command": "xstateMachineOutline.setGroupHandlersOff",
        "title": "Handlers: flat"
      },
      {
        "command": "xstateMachineOutline.setSortChildrenSorted",
        "title": "Sort children: A–Z"
      },
      {
        "command": "xstateMachineOutline.setSortChildrenOriginal",
        "title": "Sort children: source order"
      },
      {
        "command": "xstateMachineOutline.setErrorsGroupingFile",
        "title": "Group: by file",
        "icon": "$(list-tree)"
      },
      {
        "command": "xstateMachineOutline.setErrorsGroupingSeverity",
        "title": "Group: by severity",
        "icon": "$(warning)"
      },
      {
        "command": "xstateMachineOutline.setErrorsGroupingFlat",
        "title": "Group: flat",
        "icon": "$(list-flat)"
      },
      {
        "command": "xstateErrors.open",
        "title": "Go to Problem"
      },
      {
        "command": "xstateErrors.copy",
        "title": "Copy",
        "icon": "$(copy)"
      },
      {
        "command": "xstateMachineOutline.setErrorsFilterAll",
        "title": "Show: all",
        "icon": "$(list-filter)"
      },
      {
        "command": "xstateMachineOutline.setErrorsFilterWarnings",
        "title": "Show: warnings & errors",
        "icon": "$(warning)"
      },
      {
        "command": "xstateMachineOutline.setErrorsFilterErrors",
        "title": "Show: errors only",
        "icon": "$(error)"
      },
      {
        "command": "xstateMachineOutline.navigateToNode",
        "title": "Go to Source"
      },
      {
        "command": "xstateMachineOutline.goToSource",
        "title": "Go to Source",
        "category": "XState",
        "icon": "$(go-to-file)"
      },
      {
        "command": "xstateMachineOutline.goToImplementation",
        "title": "Go to Implementation",
        "icon": "$(go-to-file)"
      },
      {
        "command": "xstateMachineOutline.showTransitions",
        "title": "Show Transitions",
        "icon": "$(arrow-both)"
      },
      {
        "command": "xstateNavigator.openTransition",
        "title": "Go to State"
      },
      {
        "command": "xstateMachineOutline.filter",
        "title": "Filter",
        "icon": "$(search)"
      },
      {
        "command": "xstateMachineOutline.clearFilter",
        "title": "Clear Filter",
        "icon": "$(search-stop)"
      },
      {
        "command": "xstateMachineOutline.goToImplementationSelected",
        "title": "Go to Implementation",
        "icon": "$(go-to-file)"
      },
      {
        "command": "xstateMachineOutline.editNode",
        "title": "Edit"
      },
      {
        "command": "xstateMachineOutline.addChildState",
        "title": "Add Child State"
      },
      {
        "command": "xstateMachineOutline.addTransition",
        "title": "Add Transition"
      },
      {
        "command": "xstateMachineOutline.addReference",
        "title": "Add Action / Guard / Invoke"
      },
      {
        "command": "xstateMachineOutline.deleteNode",
        "title": "Delete"
      },
      {
        "command": "xstateMachineOutline.setDescription",
        "title": "Set Description"
      },
      {
        "command": "xstateMachineOutline.openGraphView",
        "title": "View State Diagram",
        "icon": "$(git-merge)"
      },
      {
        "command": "xstateMachineOutline.openGraphViewAtCursor",
        "title": "View State Diagram",
        "category": "XState",
        "icon": "$(git-merge)"
      },
      {
        "command": "xstateMachineOutline.openGraphViewForNode",
        "title": "View State Diagram",
        "category": "XState"
      },
      {
        "command": "xstateMachineOutline.exportMermaid",
        "title": "Export as Mermaid",
        "category": "XState",
        "icon": "$(markdown)"
      },
      {
        "command": "xstateMachineOutline.generateSetupStubs",
        "title": "Generate Setup Stubs",
        "category": "XState",
        "icon": "$(symbol-method)"
      },
      {
        "command": "xstateMachineOutline.generateTestPaths",
        "title": "Generate Test Paths",
        "category": "XState",
        "icon": "$(beaker)"
      }
    ],
    "configuration": {
      "title": "XState Outline",
      "properties": {
        "xstateOutline.debuggerUrl": {
          "type": "string",
          "default": "ws://127.0.0.1:9301",
          "description": "WebSocket URL of the running app's XState server adapter (createServerAdapter) that the live debugger connects to."
        },
        "xstateOutline.debuggerShowStopped": {
          "type": "boolean",
          "default": true,
          "description": "Show stopped actors in the XState Debugger Instances view."
        },
        "xstateOutline.defaultScope": {
          "type": "string",
          "enum": [
            "file",
            "workspace"
          ],
          "default": "workspace",
          "description": "Default scope for XState Outline view (file or workspace)"
        },
        "xstateOutline.defaultViewMode": {
          "type": "string",
          "enum": [
            "grouped",
            "flat"
          ],
          "default": "flat",
          "description": "Default view mode (grouped by file or flat list of machines)"
        },
        "xstateOutline.showStateConfigs": {
          "type": "boolean",
          "default": false,
          "description": "Show createStateConfig/stateConfig patterns in the outline"
        },
        "xstateOutline.followCursor": {
          "type": "boolean",
          "default": true,
          "description": "Automatically reveal the tree item corresponding to the cursor position"
        },
        "xstateOutline.navTarget": {
          "type": "string",
          "enum": [
            "code",
            "diagram"
          ],
          "enumDescriptions": [
            "Clicking a state/machine in the outline jumps to its source",
            "Clicking a state/machine focuses it in the diagram (opening the diagram if needed)"
          ],
          "default": "code",
          "description": "Where clicking a tree node navigates: source code or the statechart diagram"
        },
        "xstateOutline.graphReflectsTreeExpansion": {
          "type": "boolean",
          "default": true,
          "description": "Make the visual graph selectively render only states that are expanded in the tree outline"
        },
        "xstateOutline.codeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show a CodeLens above each machine with state/transition counts and a 'View Diagram' action"
        },
        "xstateOutline.showInternalTransitions": {
          "type": "boolean",
          "default": true,
          "description": "Show internal (action-only) transitions inside state boxes in the diagram (toggle live from the diagram toolbar)"
        },
        "xstateOutline.groupEventHandlers": {
          "type": "boolean",
          "default": false,
          "description": "Group a state's event-handler transitions under an `on` node in the outline"
        },
        "xstateOutline.sortChildren": {
          "type": "string",
          "enum": [
            "original",
            "sorted"
          ],
          "default": "original",
          "description": "Order of child nodes in the outline: source order (original) or alphabetical (sorted)"
        },
        "xstateOutline.errorsGrouping": {
          "type": "string",
          "enum": [
            "file",
            "severity",
            "flat"
          ],
          "default": "file",
          "description": "How the Errors pane groups problems: by file, by severity, or a flat list"
        },
        "xstateOutline.errorsFilter": {
          "type": "string",
          "enum": [
            "all",
            "warning",
            "error"
          ],
          "enumDescriptions": [
            "Show everything, including deprecations and unused-setup hints",
            "Show errors and warnings (hide informational hints)",
            "Show only errors — problems that fail at runtime"
          ],
          "default": "warning",
          "description": "Minimum severity shown in the Errors pane"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "xstateDebugger.connect",
          "when": "view == xstateDebuggerInstances && !xstateDebugger.connected",
          "group": "navigation@0"
        },
        {
          "command": "xstateDebugger.disconnect",
          "when": "view == xstateDebuggerInstances && xstateDebugger.connected",
          "group": "navigation@0"
        },
        {
          "command": "xstateDebugger.hideStopped",
          "when": "view == xstateDebuggerInstances && xstateDebugger.showStopped",
          "group": "1_visibility@1"
        },
        {
          "command": "xstateDebugger.showStopped",
          "when": "view == xstateDebuggerInstances && !xstateDebugger.showStopped",
          "group": "1_visibility@1"
        },
        {
          "command": "xstateDebugger.stepBack",
          "when": "view == xstateEventsLog",
          "group": "navigation@0"
        },
        {
          "command": "xstateDebugger.stepForward",
          "when": "view == xstateEventsLog",
          "group": "navigation@1"
        },
        {
          "command": "xstateDebugger.backToLive",
          "when": "view == xstateEventsLog && xstateDebugger.timeTravelling",
          "group": "navigation@2"
        },
        {
          "command": "xstateDebugger.clearEvents",
          "when": "view == xstateEventsLog",
          "group": "navigation@3"
        },
        {
          "command": "xstateDebugger.importSession",
          "when": "view == xstateEventsLog",
          "group": "1_session@0"
        },
        {
          "command": "xstateDebugger.exportSession",
          "when": "view == xstateEventsLog",
          "group": "1_session@1"
        },
        {
          "command": "xstateMachineOutline.refresh",
          "when": "view == xstateMachineOutline",
          "group": "navigation@3"
        },
        {
          "command": "xstateMachineOutline.toggleGraphSyncExpansion",
          "when": "view == xstateMachineOutline && !xstateOutline.graphReflectsTreeExpansion",
          "group": "0_cursor@0"
        },
        {
          "command": "xstateMachineOutline.toggleGraphSyncExpansionActive",
          "when": "view == xstateMachineOutline && xstateOutline.graphReflectsTreeExpansion",
          "group": "0_cursor@0"
        },
        {
          "command": "xstateMachineOutline.toggleFollowCursor",
          "when": "view == xstateMachineOutline && !xstateOutline.followCursor",
          "group": "0_cursor@1"
        },
        {
          "command": "xstateMachineOutline.toggleFollowCursorActive",
          "when": "view == xstateMachineOutline && xstateOutline.followCursor",
          "group": "0_cursor@1"
        },
        {
          "command": "xstateMachineOutline.setNavDiagram",
          "when": "view == xstateMachineOutline && !xstateOutline.navIsDiagram",
          "group": "0_cursor@2"
        },
        {
          "command": "xstateMachineOutline.setNavCode",
          "when": "view == xstateMachineOutline && xstateOutline.navIsDiagram",
          "group": "0_cursor@2"
        },
        {
          "command": "xstateMachineOutline.setScopeFile",
          "when": "view == xstateMachineOutline && xstateOutline.scopeIsWorkspace",
          "group": "1_scope@1"
        },
        {
          "command": "xstateMachineOutline.setScopeWorkspace",
          "when": "view == xstateMachineOutline && !xstateOutline.scopeIsWorkspace",
          "group": "1_scope@2"
        },
        {
          "command": "xstateMachineOutline.setViewGrouped",
          "when": "view == xstateMachineOutline && xstateOutline.viewModeIsFlat",
          "group": "2_view@1"
        },
        {
          "command": "xstateMachineOutline.setViewFlat",
          "when": "view == xstateMachineOutline && !xstateOutline.viewModeIsFlat",
          "group": "2_view@2"
        },
        {
          "command": "xstateMachineOutline.setStateConfigsShow",
          "when": "view == xstateMachineOutline && !xstateOutline.showStateConfigs",
          "group": "3_configs@1"
        },
        {
          "command": "xstateMachineOutline.setStateConfigsHide",
          "when": "view == xstateMachineOutline && xstateOutline.showStateConfigs",
          "group": "3_configs@2"
        },
        {
          "command": "xstateMachineOutline.setGroupHandlersOn",
          "when": "view == xstateMachineOutline && !xstateOutline.groupEventHandlers",
          "group": "4_handlers@1"
        },
        {
          "command": "xstateMachineOutline.setGroupHandlersOff",
          "when": "view == xstateMachineOutline && xstateOutline.groupEventHandlers",
          "group": "4_handlers@2"
        },
        {
          "command": "xstateMachineOutline.setSortChildrenSorted",
          "when": "view == xstateMachineOutline && !xstateOutline.sortChildrenIsSorted",
          "group": "5_sort@1"
        },
        {
          "command": "xstateMachineOutline.setSortChildrenOriginal",
          "when": "view == xstateMachineOutline && xstateOutline.sortChildrenIsSorted",
          "group": "5_sort@2"
        },
        {
          "command": "xstateMachineOutline.setErrorsFilterAll",
          "when": "view == xstateMachineErrors && xstateErrors.filter != all",
          "group": "0_filter@1"
        },
        {
          "command": "xstateMachineOutline.setErrorsFilterWarnings",
          "when": "view == xstateMachineErrors && xstateErrors.filter != warning",
          "group": "0_filter@2"
        },
        {
          "command": "xstateMachineOutline.setErrorsFilterErrors",
          "when": "view == xstateMachineErrors && xstateErrors.filter != error",
          "group": "0_filter@3"
        },
        {
          "command": "xstateMachineOutline.setErrorsGroupingFile",
          "when": "view == xstateMachineErrors && xstateErrors.grouping != file",
          "group": "1_grouping@1"
        },
        {
          "command": "xstateMachineOutline.setErrorsGroupingSeverity",
          "when": "view == xstateMachineErrors && xstateErrors.grouping != severity",
          "group": "1_grouping@2"
        },
        {
          "command": "xstateMachineOutline.setErrorsGroupingFlat",
          "when": "view == xstateMachineErrors && xstateErrors.grouping != flat",
          "group": "1_grouping@3"
        }
      ],
      "view/item/context": [
        {
          "command": "xstateDebugger.goToSource",
          "when": "view == xstateDebuggerInstances && (viewItem == xstateDebuggerActor || viewItem == xstateDebuggerState)",
          "group": "navigation@0"
        },
        {
          "command": "xstateDebugger.revealInDiagram",
          "when": "view == xstateDebuggerInstances && (viewItem == xstateDebuggerActor || viewItem == xstateDebuggerState)",
          "group": "navigation@1"
        },
        {
          "command": "xstateDebugger.sendEvent",
          "when": "view == xstateDebuggerInstances && (viewItem == xstateDebuggerActor || viewItem == xstateDebuggerState)",
          "group": "1_actor@0"
        },
        {
          "command": "xstateDebugger.captureSnapshot",
          "when": "view == xstateDebuggerInstances && viewItem == xstateDebuggerActor",
          "group": "1_actor@1"
        },
        {
          "command": "xstateDebugger.restoreSnapshot",
          "when": "view == xstateDebuggerInstances && viewItem == xstateDebuggerActor",
          "group": "1_actor@2"
        },
        {
          "command": "xstateDebugger.copyContextValue",
          "when": "view == xstateDebuggerContext && viewItem == xstateDebuggerContext",
          "group": "navigation@0"
        },
        {
          "command": "xstateMachineOutline.goToSource",
          "when": "view == xstateMachineOutline && xstateOutline.navIsDiagram && (viewItem == machine || viewItem == state)",
          "group": "navigation@0"
        },
        {
          "command": "xstateMachineOutline.openGraphView",
          "when": "view == xstateMachineOutline && (viewItem == machine || viewItem == state)",
          "group": "navigation@1"
        },
        {
          "command": "xstateMachineOutline.exportMermaid",
          "when": "view == xstateMachineOutline && (viewItem == machine || viewItem == state)",
          "group": "navigation@3"
        },
        {
          "command": "xstateMachineOutline.generateTestPaths",
          "when": "view == xstateMachineOutline && viewItem == machine",
          "group": "navigation@5"
        },
        {
          "command": "xstateMachineOutline.generateSetupStubs",
          "when": "view == xstateMachineOutline && viewItem == machine",
          "group": "navigation@6"
        },
        {
          "command": "xstateMachineOutline.goToImplementation",
          "when": "view == xstateMachineOutline && (viewItem == action || viewItem == guard || viewItem == entry || viewItem == exit || viewItem == invoke || viewItem == target)",
          "group": "navigation@1"
        },
        {
          "command": "xstateMachineOutline.showTransitions",
          "when": "view == xstateMachineOutline && viewItem == state",
          "group": "navigation@2"
        },
        {
          "command": "xstateMachineOutline.editNode",
          "when": "view == xstateMachineOutline && (viewItem == state || viewItem == transition || viewItem == target || viewItem == action || viewItem == guard || viewItem == invoke || viewItem == contextProperty || viewItem == actor || viewItem == delay || viewItem == invalid)",
          "group": "edit@1"
        },
        {
          "command": "xstateMachineOutline.addChildState",
          "when": "view == xstateMachineOutline && (viewItem == machine || viewItem == state)",
          "group": "edit@2"
        },
        {
          "command": "xstateMachineOutline.addTransition",
          "when": "view == xstateMachineOutline && viewItem == state",
          "group": "edit@3"
        },
        {
          "command": "xstateMachineOutline.addReference",
          "when": "view == xstateMachineOutline && (viewItem == machine || viewItem == state || viewItem == transition || viewItem == setup || viewItem == action || viewItem == guard || viewItem == actor || viewItem == delay || viewItem == invoke)",
          "group": "edit@4"
        },
        {
          "command": "xstateMachineOutline.deleteNode",
          "when": "view == xstateMachineOutline && (viewItem == state || viewItem == transition || viewItem == target || viewItem == action || viewItem == guard || viewItem == invoke || viewItem == contextProperty || viewItem == actor || viewItem == delay || viewItem == invalid)",
          "group": "edit@5"
        },
        {
          "command": "xstateMachineOutline.setDescription",
          "when": "view == xstateMachineOutline && (viewItem == machine || viewItem == state)",
          "group": "edit@6"
        },
        {
          "command": "xstateErrors.copy",
          "when": "view == xstateMachineErrors && (viewItem == errorIssue || viewItem == errorFileGroup || viewItem == errorSeverityGroup)",
          "group": "9_copy@1"
        }
      ],
      "view/item/inline": [
        {
          "command": "xstateMachineOutline.openGraphView",
          "when": "view == xstateMachineOutline && (viewItem == machine || viewItem == state)",
          "group": "inline@1"
        },
        {
          "command": "xstateMachineOutline.goToImplementation",
          "when": "view == xstateMachineOutline && (viewItem == action || viewItem == guard || viewItem == entry || viewItem == exit || viewItem == invoke || viewItem == target)",
          "group": "inline"
        }
      ],
      "editor/context": [
        {
          "command": "xstateMachineOutline.openGraphViewAtCursor",
          "when": "xstateOutline.editorHasMachine",
          "group": "navigation@9"
        }
      ],
      "commandPalette": [
        {
          "command": "xstateDebugger.copyContextValue",
          "when": "false"
        },
        {
          "command": "xstateDebugger.goToSource",
          "when": "false"
        },
        {
          "command": "xstateDebugger.revealInDiagram",
          "when": "false"
        },
        {
          "command": "xstateDebugger.sendEvent",
          "when": "false"
        },
        {
          "command": "xstateDebugger.captureSnapshot",
          "when": "false"
        },
        {
          "command": "xstateDebugger.restoreSnapshot",
          "when": "false"
        },
        {
          "command": "xstateMachineOutline.goToSource",
          "when": "false"
        },
        {
          "command": "xstateMachineOutline.openGraphView",
          "when": "false"
        },
        {
          "command": "xstateMachineOutline.openGraphViewForNode",
          "when": "false"
        },
        {
          "command": "xstateMachineOutline.exportMermaid",
          "when": "false"
        },
        {
          "command": "xstateMachineOutline.generateTestPaths",
          "when": "false"
        },
        {
          "command": "xstateMachineOutline.generateSetupStubs",
          "when": "false"
        },
        {
          "command": "xstateMachineOutline.showTransitions",
          "when": "false"
        },
        {
          "command": "xstateNavigator.openTransition",
          "when": "false"
        },
        {
          "command": "xstateErrors.open",
          "when": "false"
        },
        {
          "command": "xstateErrors.copy",
          "when": "false"
        },
        {
          "command": "xstateMachineOutline.setErrorsGroupingFile",
          "when": "false"
        },
        {
          "command": "xstateMachineOutline.setErrorsGroupingSeverity",
          "when": "false"
        },
        {
          "command": "xstateMachineOutline.setErrorsGroupingFlat",
          "when": "false"
        },
        {
          "command": "xstateMachineOutline.setErrorsFilterAll",
          "when": "false"
        },
        {
          "command": "xstateMachineOutline.setErrorsFilterWarnings",
          "when": "false"
        },
        {
          "command": "xstateMachineOutline.setErrorsFilterErrors",
          "when": "false"
        },
        {
          "command": "xstateMachineOutline.openGraphViewAtCursor",
          "when": "xstateOutline.editorHasMachine"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "xstate-outline",
          "title": "xState Devtools",
          "icon": "resources/xstate.svg"
        },
        {
          "id": "xstate-debugger",
          "title": "XState Debugger",
          "icon": "resources/debugger.svg"
        }
      ],
      "panel": [
        {
          "id": "xstate-events",
          "title": "XState",
          "icon": "resources/xstate.svg"
        }
      ]
    },
    "keybindings": [
      {
        "command": "xstateMachineOutline.goToImplementationSelected",
        "key": "f12",
        "mac": "f12",
        "when": "focusedView == xstateMachineOutline"
      },
      {
        "command": "xstateErrors.copy",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "focusedView == xstateMachineErrors"
      }
    ]
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "vscode:prepublish": "npm run copy-codicons && npm run bundle",
    "copy-codicons": "node -e \"const fs=require('fs'),p=require('path');const dist=p.dirname(require.resolve('@vscode/codicons/package.json'))+'/dist';const out='resources/codicons';fs.mkdirSync(out,{recursive:true});for(const f of ['codicon.css','codicon.ttf'])fs.copyFileSync(p.join(dist,f),p.join(out,f));\"",
    "bundle": "node esbuild.js",
    "compile": "npm run copy-codicons && npm run bundle",
    "build": "npm run copy-codicons && npm run bundle",
    "watch": "npm run copy-codicons && node esbuild.js --watch",
    "dev": "npm run copy-codicons && node esbuild.js --watch",
    "check": "tsc -p ./ --noEmit",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.78.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/codicons": "^0.0.45",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.17.6",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@xstate-devtools/panel-core": "*",
